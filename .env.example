# OpenInsight 环境变量配置
# 复制此文件为 .env 后填入你的凭据：cp .env.example .env

# ============================================================
# GitHub（必需）
# ============================================================
# GitHub Personal Access Token，需要 repo 读取权限
# 获取方式：https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# ============================================================
# Discourse 论坛（可选）
# ============================================================
# PyTorch Discourse 论坛 API 凭据
# 如不配置，论坛相关数据将跳过采集
# 获取方式：https://discuss.pytorch.org 用户设置 → API Keys
DISCOURSE_API_KEY=
DISCOURSE_API_USERNAME=
