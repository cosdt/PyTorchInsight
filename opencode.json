{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md"
  ],
  "tools": {
    "openinsight-github*": true,
    "openinsight-web*": true,
    "openinsight-slack*": true
  },
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {file:~/.config/opencode/.secrets/github-pat}"
      }
    },
    "slack": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e", "SLACK_MCP_XOXC_TOKEN",
        "-e", "SLACK_MCP_XOXD_TOKEN",
        "ghcr.io/korotovsky/slack-mcp-server:latest",
        "--transport",
        "stdio"
      ],
      "enabled": false,
      "timeout": 30000
    },
    "pytorch-community":{
      "type": "local",
      "command":[
        "uv",
        "run",
        "--directory",
        "/Users/chu/project/openinsight_mcp",
        "pytorch-community-mcp"
      ]
    }
  }
}
